# IWS file-worker 环境变量示例。复制为 file-worker/.env 后按环境修改。

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://iws:iws_dev_password@localhost:5432/iws

# -----------------------------------------------------------------------------
# Object Storage / MinIO / S3
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_FORCE_PATH_STYLE=true
S3_PROJECT_FILES_BUCKET=project-files

# -----------------------------------------------------------------------------
# Preview conversion
# -----------------------------------------------------------------------------
GOTENBERG_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Worker polling
# -----------------------------------------------------------------------------
FILE_WORKER_ID=local-file-worker
FILE_WORKER_POLL_INTERVAL_SECONDS=2
FILE_WORKER_VISIBILITY_TIMEOUT_SECONDS=300
FILE_WORKER_MAX_MESSAGES=5

# -----------------------------------------------------------------------------
# PaddleOCR
# -----------------------------------------------------------------------------
PADDLEOCR_TOKEN=
PADDLEOCR_JOB_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
PADDLEOCR_MODEL=PaddleOCR-VL-1.6
PADDLEOCR_POLL_INTERVAL_SECONDS=5
PADDLEOCR_MAX_WAIT_SECONDS=1800

# -----------------------------------------------------------------------------
# DashScope embedding
# -----------------------------------------------------------------------------
DASHSCOPE_API_KEY=
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/text-embedding/text-embedding
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1536
EMBEDDING_BATCH_SIZE=10

# Internal HTTP service used by web for query embedding.
EMBEDDING_SERVICE_HOST=0.0.0.0
EMBEDDING_SERVICE_PORT=8010
EMBEDDING_SERVICE_TOKEN=
