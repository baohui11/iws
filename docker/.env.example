# IWS Docker Compose 环境变量示例。复制为 docker/.env 后按环境修改。

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=iws
POSTGRES_PASSWORD=iws_dev_password
POSTGRES_DB=iws
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Web / Auth
# -----------------------------------------------------------------------------
WEB_PORT=3000
APP_BASE_URL=http://localhost:3000
AUTH_SECRET=change-me-to-a-strong-random-secret
FILE_UPLOAD_TOKEN_SECRET=
RUN_DB_MIGRATIONS=true
SEED_ADMIN_ON_STARTUP=true
SEED_ADMIN_EMAIL=admin@iws.local
SEED_ADMIN_PASSWORD=admin12345

# -----------------------------------------------------------------------------
# MinIO / S3
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_API_CORS_ALLOW_ORIGIN=*
S3_PROJECT_FILES_BUCKET=project-files
S3_AVATAR_BUCKET=avatars
S3_PUBLIC_ENDPOINT=http://localhost:9000
IWS_PROJECT_FILES_MAX_BYTES=524288000
NEXT_PUBLIC_ENCRYPT_GATEWAY_APP_ID=

# -----------------------------------------------------------------------------
# SMTP Mail
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=周报文件系统 <noreply@example.com>
SMTP_TIMEOUT_MS=10000
SMTP_TLS_REJECT_UNAUTHORIZED=true

# -----------------------------------------------------------------------------
# OA Sync
# -----------------------------------------------------------------------------
OA_PGREST_BASE_URL=https://mpdata01.mpgroup.cn:8081
OA_PGREST_TOKEN=
OA_PGREST_PAGE_SIZE=200
OA_PGREST_PROJECT_PAGE_SIZE=500
OA_PGREST_PROJECT_ROLE_PAGE_SIZE=500
OA_SYNC_SCHEDULE_ENABLED=true
OA_SYNC_SCHEDULE_CRON=0 4,13 * * *

# -----------------------------------------------------------------------------
# Gotenberg / file-worker
# -----------------------------------------------------------------------------
GOTENBERG_PORT=3001
FILE_WORKER_POLL_INTERVAL_SECONDS=2
FILE_WORKER_VISIBILITY_TIMEOUT_SECONDS=300
FILE_WORKER_MAX_MESSAGES=5

# -----------------------------------------------------------------------------
# PaddleOCR
# -----------------------------------------------------------------------------
PADDLEOCR_TOKEN=
PADDLEOCR_JOB_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
PADDLEOCR_MODEL=PaddleOCR-VL-1.6
PADDLEOCR_POLL_INTERVAL_SECONDS=5
PADDLEOCR_MAX_WAIT_SECONDS=1800

# -----------------------------------------------------------------------------
# DashScope Embedding
# -----------------------------------------------------------------------------
DASHSCOPE_API_KEY=
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/text-embedding/text-embedding
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1536
EMBEDDING_BATCH_SIZE=10
EMBEDDING_SERVICE_PORT=8010
EMBEDDING_SERVICE_TOKEN=
