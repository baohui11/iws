# 一次性历史数据迁移配置
# 复制为 legacy-migration/.env 后填写。不要提交真实密钥。

# -----------------------------------------------------------------------------
# 旧 Supabase PostgreSQL
# -----------------------------------------------------------------------------
# 建议使用只读账号。用于读取旧系统业务表、storage.objects 等元数据。
LEGACY_DATABASE_URL=postgresql://readonly_user:password@host:5432/postgres?sslmode=require

# 可选：如果旧库 schema 不是 public，在这里覆盖。
LEGACY_DB_SCHEMA=public

# -----------------------------------------------------------------------------
# 旧 Supabase Storage 本地目录
# -----------------------------------------------------------------------------
# 把旧 Supabase docker/volumes/storage 目录拷贝到本地后，配置到 stub/stub
# 这一层。目录下应包含 project-files / avatars。
# 示例：E:\app\iws\temp\storage\stub\stub
LEGACY_SUPABASE_STORAGE_LOCAL_ROOT=

# -----------------------------------------------------------------------------
# 新系统 PostgreSQL
# -----------------------------------------------------------------------------
# 目标库。应当是已经执行过当前系统迁移的 PostgreSQL。
TARGET_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/iws

# -----------------------------------------------------------------------------
# 新系统 MinIO / S3
# -----------------------------------------------------------------------------
TARGET_S3_ENDPOINT=http://localhost:9000
TARGET_S3_PUBLIC_ENDPOINT=http://localhost:9000
TARGET_S3_REGION=us-east-1
TARGET_S3_ACCESS_KEY=
TARGET_S3_SECRET_KEY=
TARGET_S3_FORCE_PATH_STYLE=true
TARGET_S3_PROJECT_FILES_BUCKET=project-files
TARGET_S3_AVATAR_BUCKET=avatars

# -----------------------------------------------------------------------------
# 文件迁移与重新处理
# -----------------------------------------------------------------------------
# true：迁移文件后在新库写入待处理任务，让 file-worker 重新生成预览、解析、分块、索引。
# 建议数据核对完成后再改为 true。
MIGRATION_ENQUEUE_FILE_JOBS=false

# true：只检查连接、统计数量、输出迁移计划，不写入目标库和 MinIO。
MIGRATION_DRY_RUN=true

# 单批处理数量。正式跑可按机器和网络情况调大。
MIGRATION_BATCH_SIZE=100

# 临时文件目录。用于从 Supabase 下载后再上传 MinIO，可留空使用系统临时目录。
MIGRATION_TMP_DIR=

# 迁移日志目录。
MIGRATION_LOG_DIR=legacy-migration/logs

# -----------------------------------------------------------------------------
# 迁移范围开关
# -----------------------------------------------------------------------------
MIGRATE_DEPARTMENTS=true
MIGRATE_USERS=true
MIGRATE_PROJECTS=true
MIGRATE_PROJECT_MEMBERS=true
MIGRATE_WEEKLY_REPORTS=true
MIGRATE_FILES=true
MIGRATE_AVATARS=true

# -----------------------------------------------------------------------------
# 旧数据映射辅助
# -----------------------------------------------------------------------------
# 如果旧系统用户 id 与新系统无法直接对应，优先用 employee_no/email 做匹配。
MIGRATION_USER_MATCH_KEYS=employee_no,email

# 如果旧系统项目 id 与新系统无法直接对应，优先用 project_no 做匹配。
MIGRATION_PROJECT_MATCH_KEYS=project_no
