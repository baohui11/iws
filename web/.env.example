# 复制为 .env 后按需修改。

# 数据库（对应 docker/docker-compose.yml 启动的 PostgreSQL 17）
DATABASE_URL=postgresql://iws:iws_dev_password@localhost:5432/iws

# 会话 JWT 签名密钥（生产务必改为强随机值，例如 `openssl rand -base64 32`）
AUTH_SECRET=change-me

# 初始管理员（仅 db:seed 使用）
SEED_ADMIN_EMAIL=admin@iws.local
SEED_ADMIN_PASSWORD=admin12345

# ---- 对象存储（MinIO / S3 兼容）----
## Server-side S3 endpoint used by Next.js/API routes.
## If web runs inside Docker, use http://minio:9000.
## If web runs on the host machine, use http://localhost:9000.
S3_ENDPOINT=http://localhost:9000
# 浏览器可访问的公开 origin（头像公开 URL 用）；不填则回退 S3_ENDPOINT
## Browser-accessible S3 endpoint used for public URLs and signed URLs.
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
# 两个桶（默认即旧值，可不显式设置）
S3_PROJECT_FILES_BUCKET=project-files
S3_AVATAR_BUCKET=avatars
# 路径风格寻址（MinIO 需 true）
S3_FORCE_PATH_STYLE=true

# ---- 邮件（企业微信邮箱 / 腾讯企业邮 SMTP）----
# 参考：服务器 smtp.exmail.qq.com，SSL 端口 465（或 STARTTLS 587）
# SMTP_PASSWORD 为「客户端专用密码」，不是登录密码
SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=周报系统 <noreply@yourcompany.com>

# ---- 文档检索（doc-processor / SearchPort HTTP 适配）----
# SEARCH_API_BASE_URL=http://127.0.0.1:8080
# SEARCH_API_KEY=

# ---- 文件处理服务（file-worker）----
# Gotenberg 用于 Word/PPT -> PDF 预览版本生成。
# GOTENBERG_URL=http://localhost:3001

# ---- 可选：加密网关（上传/下载临时文件加解密）----
# IWS_TEMP_DIR=@temp
# IWS_ENCRYPT_BASE_URL=
# IWS_ENCRYPT_NAME=
# IWS_ENCRYPT_PASSWORD=
